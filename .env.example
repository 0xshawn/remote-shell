# Copy to .env and edit before running `docker compose up` (from the repo root).
AUTH_USER=admin
AUTH_PASS=change-me-please

# Stable secret so login tokens survive restarts. Generate with: openssl rand -hex 32
TOKEN_SECRET=replace-with-a-long-random-string

# Minutes a DETACHED & idle session is kept before being reaped (0 = forever).
SESSION_TIMEOUT=0

# Per-session scrollback buffer kept in server memory, in bytes (default 2 MiB).
# This is what gets replayed to repaint the screen on reconnect.
RING_BYTES=2097152

LOG_LEVEL=info

# Optional domain for nginx server_name (injected into the nginx template via
# envsubst). Leave empty for a catch-all "_" that serves on any IP/host.
SERVER_NAME=

# --- Log into the HOST instead of the container's shell (SSH mode) ---
# docker-compose.yml already defaults these to reach the host. To turn SSH mode
# OFF and use the container's own shell, set SSH_HOST to an empty value below.
# SSH_HOST=host.docker.internal
# SSH_USER=youruser
# SSH_PORT=22
# SSH_KEY=/home/shell/.ssh/id_hostshell
