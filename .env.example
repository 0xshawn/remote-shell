# Everything here is an OPTIONAL override. The simplest first deploy is just:
#   ./deploy.sh
# which creates this file, auto-detects SSH_USER, generates the secrets, and
# authorizes the host SSH key for you. Edit below only to pin explicit values.

AUTH_USER=admin
# Blank -> a password is generated on first boot, persisted, and printed to the
# logs (stable across restarts). Set a value to pin your own.
AUTH_PASS=

# Blank -> a stable TOKEN_SECRET is generated once and persisted to the
# shell-home volume, so login tokens survive restarts. No openssl needed.
TOKEN_SECRET=

# Minutes a DETACHED & idle session is kept before being reaped (default 20160 = 14 days; 0 = forever).
SESSION_TIMEOUT=20160

# Per-session scrollback buffer kept in server memory, in bytes (default 2 MiB).
# This is what gets replayed to repaint the screen on reconnect.
RING_BYTES=2097152

LOG_LEVEL=info

# Optional domain for nginx server_name (injected into the nginx template via
# envsubst). Leave empty for a catch-all "_" that serves on any IP/host.
SERVER_NAME=

# --- Log into the HOST instead of the container's shell (SSH mode) ---
# On by default; deploy.sh sets SSH_USER and authorizes the key for you. To turn
# SSH mode OFF and use the container's own shell, set SSH_HOST to an empty value.
# SSH_HOST=host.docker.internal
# SSH_USER=youruser
# SSH_PORT=22
# SSH_KEY=/home/shell/.ssh/id_hostshell
