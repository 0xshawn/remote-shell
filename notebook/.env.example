# Copy to .env (gitignored) and fill in. Used by docker-compose.yml.

# --- app login ---
AUTH_USER=admin
AUTH_PASS=changeme
# Generate a stable secret:  openssl rand -hex 32
TOKEN_SECRET=please-change-this-secret

# Host port to publish (reachable at http://<host-ip>:<port>).
# Pick one your firewall allows (e.g. the 8080-9090 range).
NOTEBOOK_PORT=8088

# --- Run shell + claude on the HOST as your user (over SSH) ---
# The container SSHes back to the host so the shell tab AND claude use your real
# host environment + config. SSH_USER is the host account whose authorized_keys
# holds the container key (see README for the one-time key setup).
SSH_USER=youruser

# --- Claude on the host ---
# CLAUDE_BIN : absolute path to the host's claude binary.
#   Find it on the host with:  which claude   (e.g. an nvm path).
# CLAUDE_CWD : host working directory for new claude sessions.
# CLAUDE_ENV : extra env for claude; point CLAUDE_CONFIG_DIR at your host config
#   so claude reuses your existing auth (find it on the host with:
#   echo $CLAUDE_CONFIG_DIR  — defaults to ~/.claude if unset).
CLAUDE_BIN=/home/youruser/.nvm/versions/node/vXX/bin/claude
CLAUDE_CWD=/home/youruser
CLAUDE_ENV=CLAUDE_CONFIG_DIR=/home/youruser/.claude
CLAUDE_PERMISSION_MODE=acceptEdits
