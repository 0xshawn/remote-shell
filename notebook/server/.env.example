# Copy to .env and adjust. All values are optional; CLI flags override env vars.

# --- auth / server ---
AUTH_USER=admin
AUTH_PASS=
TOKEN_SECRET=
PORT=7682

# --- shell (tmux-backed) ---
# SHELL_PATH=/bin/bash
# WORK_DIR=/home/youruser

# --- claude launch profile ---
# CLAUDE_BIN=claude
# CLAUDE_MODEL=
CLAUDE_PERMISSION_MODE=acceptEdits
# CLAUDE_CWD=/home/youruser/code
# CLAUDE_EXTRA_ARGS=
# Inject env into the claude child (space-separated KEY=VALUE pairs).
# Pass CLAUDE_CONFIG_DIR through if your host overrides it, so transcripts land predictably.
# CLAUDE_ENV=CLAUDE_CONFIG_DIR=/home/youruser/.claude
# MAX_CLAUDE_SESSIONS=0
# CLAUDE_IDLE_TIMEOUT=0
